{
  "expo": {
    "name": "FastTarot",
    "slug": "fasttarot",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "fasttarot",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a0a0f",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fasttarot.app"
    },
    "android": {
      "package": "com.fasttarot.app",
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0f"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router", "expo-font", "expo-localization"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
