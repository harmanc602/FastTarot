{
  "name": "fasttarot",
  "version": "1.0.0",
  "private": true,
  "description": "Tarot card picker — responsive web app and cross-platform mobile app sharing a common core.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "web": "npm run dev --workspace apps/web",
    "web:build": "npm run build --workspace apps/web",
    "mobile": "npm run start --workspace apps/mobile",
    "gen:cards": "python packages/core/scripts/gen_cards.py",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "tsx --test packages/core/test/*.test.ts"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.3.2",
    "tsx": "^4.16.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  }
}
